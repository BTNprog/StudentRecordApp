<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.StudentRecordApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Light Ocean Blue Palette with White Accents -->
        <item name="colorPrimary">@color/ocean_blue_primary</item>
        <item name="colorPrimaryVariant">@color/ocean_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/white</item>
        <item name="colorOnSecondary">@color/ocean_blue_primary</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        
        <!-- Window Background -->
        <item name="android:windowBackground">@color/white</item>
    </style>

    <style name="Theme.StudentRecordApp" parent="Base.Theme.StudentRecordApp" />
</resources>